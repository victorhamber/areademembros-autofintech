# Copie para `.env` local (não versionar `.env`).

NODE_ENV=production
PORT=3000
APP_URL=https://app.autofintech.com.br

# Pasta de uploads (volume persistente no EasyPanel). Use /data/uploads se o volume montar aí.
UPLOAD_DIR=/data/uploads

# PostgreSQL (EasyPanel / produção)
DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco?sslmode=disable

# MariaDB do WordPress (só para npm run db:migrate:wordpress no servidor)
# WP_DATABASE_URL=mariadb://usuario:senha@host-wordpress:3306/autofintech

ADMIN_EMAIL=admin@autofintech.com.br
ADMIN_PASSWORD=troque-por-senha-forte
JWT_SECRET=troque-por-secret-longo-e-aleatorio

# Opcional: webhook Hotmart de e-books (/api/webhooks/hotmart)
HOTMART_HOTTOK=

# Robô: ativar/desativar licença após webhook
ROBOT_ACTIVATE_URL=https://autofintech.com.br/robot/activate
ROBOT_DEACTIVATE_URL=https://autofintech.com.br/robot/deactivate

RANKING_RETENTION_DAYS=30
WEBHOOK_LOG_RETENTION_DAYS=30
RAW_WEBHOOK_RETENTION_DAYS=30
TRIAL_HISTORY_RETENTION_DAYS=30
