{
  "name": "ebook-pwa",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:seed": "prisma db seed",
    "db:import:wpress-sql": "node scripts/import-clean-wpress-sql.mjs ../wp_extract/database.sql --out ./tmp/wp-clean-export.json --apply",
    "db:import:wplinks": "node scripts/import-clean-wpress-sql.mjs ../wp_extract/database.sql --out ./tmp/wp-clean-export.json --apply",
    "db:prune": "node scripts/prune-database.mjs",
    "db:prune:aggressive": "node scripts/prune-database.mjs --aggressive",
    "db:export:sqlite": "node scripts/migrate-sqlite-to-postgres.mjs --export-only",
    "db:import:postgres": "node scripts/migrate-sqlite-to-postgres.mjs --import-only ./tmp/sqlite-export.json",
    "db:migrate:sqlite-to-pg": "node scripts/migrate-sqlite-to-postgres.mjs",
    "db:migrate:wordpress": "node scripts/migrate-wordpress-mariadb-to-app.mjs",
    "db:migrate:wordpress:dry": "node scripts/migrate-wordpress-mariadb-to-app.mjs --dry-run",
    "db:consolidate:products": "node scripts/consolidate-three-products.mjs",
    "db:consolidate:products:dry": "node scripts/consolidate-three-products.mjs --dry-run",
    "db:fix:license-products": "node scripts/fix-license-products-by-plan.mjs",
    "db:fix:license-products:dry": "node scripts/fix-license-products-by-plan.mjs --dry-run",
    "db:resync:wp-passwords": "node scripts/resync-wp-passwords.mjs",
    "db:resync:wp-passwords:dry": "node scripts/resync-wp-passwords.mjs --dry-run",
    "dev:api": "tsx server/index.ts",
    "dev:full": "concurrently -n api,web -c cyan,magenta \"npm run dev:api\" \"npm run dev\"",
    "server": "npx prisma db push --accept-data-loss && tsx server/index.ts",
    "start": "npx prisma db push --accept-data-loss && tsx server/index.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mark.js": "^8.11.12",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "iconv-lite": "^0.7.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.7.0",
    "mark.js": "^8.11.1",
    "multer": "^2.1.1",
    "mysql2": "^3.22.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-pdf": "^10.4.1",
    "react-zoom-pan-pinch": "^3.7.0",
    "resend": "^6.9.4",
    "wordpress-hash-node": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "better-sqlite3": "^12.10.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prisma": "^5.22.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
