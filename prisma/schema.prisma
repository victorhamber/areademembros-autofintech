generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String?
  name      String?
  country   String?
  purchases Purchase[]
  wishlists Wishlist[]
  createdAt DateTime   @default(now())
}

model Category {
  id     String  @id @default(uuid())
  name   String  @unique
  ebooks Ebook[]
}

model Ebook {
  id            String    @id @default(uuid())
  title         String
  author        String?
  description   String?
  coverUrl      String
  pdfUrl        String?           
  htmlUrl       String?           
  salesUrl      String            
  hotmartOffer  String    
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id])
  featuredList  String?
  purchases     Purchase[]
  wishlists     Wishlist[]
  externalUrl   String?
  redirectUrl   String?
  isBonus       Boolean   @default(false)
  parentEbookId String?
  parentEbook   Ebook?    @relation("EbookBonuses", fields: [parentEbookId], references: [id])
  bonuses       Ebook[]   @relation("EbookBonuses")
  language      String    @default("pt")
  createdAt     DateTime  @default(now())
}

model Purchase {
  id         String   @id @default(uuid())
  userId     String
  ebookId    String
  user       User     @relation(fields: [userId], references: [id])
  ebook      Ebook    @relation(fields: [ebookId], references: [id])
  lastReadAt DateTime?
  lastPage   Int      @default(0)
  createdAt  DateTime @default(now())

  @@unique([userId, ebookId]) 
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  ebookId   String
  user      User     @relation(fields: [userId], references: [id])
  ebook     Ebook    @relation(fields: [ebookId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, ebookId])
}

model Highlight {
  id          String   @id @default(uuid())
  userId      String
  ebookId     String
  pageNumber  Int
  text        String
  color       String   @default("yellow")
  createdAt   DateTime @default(now())
}

model WebhookLog {
  id           String   @id @default(uuid())
  event        String
  buyerEmail   String?
  buyerName    String?
  buyerCountry String?
  productId    String?
  status       String   @default("received")
  details      String?
  createdAt    DateTime @default(now())
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}
