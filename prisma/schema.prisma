generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String?
  name      String?
  purchases Purchase[]
  wishlists Wishlist[]
  createdAt DateTime   @default(now())
}

model Category {
  id     String  @id @default(uuid())
  name   String  @unique
  ebooks Ebook[]
}

model Ebook {
  id            String    @id @default(uuid())
  title         String
  author        String?
  coverUrl      String
  pdfUrl        String            
  salesUrl      String            
  hotmartOffer  String    @unique 
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id])
  featuredList  String?
  purchases     Purchase[]
  wishlists     Wishlist[]
  createdAt     DateTime  @default(now())
}

model Purchase {
  id        String   @id @default(uuid())
  userId    String
  ebookId   String
  user      User     @relation(fields: [userId], references: [id])
  ebook     Ebook    @relation(fields: [ebookId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, ebookId]) 
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  ebookId   String
  user      User     @relation(fields: [userId], references: [id])
  ebook     Ebook    @relation(fields: [ebookId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, ebookId])
}
